{# templates/admin_web/users.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
    <h2>Список пользователей</h2>
    {# здесь логика отображения пользователей #}
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Username</th>
            <th>Имя</th>
            <th>Фамилия</th>
            <th>Tg-id</th>
            <th>Возраст</th>
            <th>Роль аи</th>
            <th>Интересы</th>
            <th>Токенов потрачено</th>
            <th>Зарегистрирован</th>
        </tr>
        </thead>
        <tbody>
        {% for user in users %}

            <tr>
                <td> <a href="{{ path('admin_user_messages', {userId: user.getId()}) }}">{{ user.getUsername() }}</a> </td>
                <td>{{ user.getFirstname() }}</td>
                <td>{{ user.getLastname() }}</td>
                <td>{{ user.getChatId() }}</td>
                <td>{{ user.getAge() }}</td>
                <td>{{ user.getAiRole() }}</td>
                <td>
                    {% for item in user.getInterests() %}
                        {{ item }},
                    {% endfor %}

                </td>
                <td>{{ user.getTotalTokensUsed() }}</td>
                <td>{{ user.getCreatedAt()|date("Y-m-d H:i:s") }}</td>

            </tr>
        {% endfor %}

        </tbody>
    </table>


{% endblock %}
